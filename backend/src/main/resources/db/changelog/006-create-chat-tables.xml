<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="006-create-conversations-table" author="system">
        <createTable tableName="conversations">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="listing_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="buyer_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="seller_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="last_message_at" type="TIMESTAMP"/>
            <column name="last_message_preview" type="VARCHAR(100)"/>
            <column name="buyer_unread_count" type="INT" defaultValueNumeric="0"/>
            <column name="seller_unread_count" type="INT" defaultValueNumeric="0"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>

        <createIndex tableName="conversations" indexName="idx_conv_listing">
            <column name="listing_id"/>
        </createIndex>
        <createIndex tableName="conversations" indexName="idx_conv_buyer">
            <column name="buyer_id"/>
        </createIndex>
        <createIndex tableName="conversations" indexName="idx_conv_seller">
            <column name="seller_id"/>
        </createIndex>
        <createIndex tableName="conversations" indexName="idx_conv_last_msg">
            <column name="last_message_at"/>
        </createIndex>
    </changeSet>

    <changeSet id="007-create-chat-messages-table" author="system">
        <createTable tableName="chat_messages">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="conversation_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="sender_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="content" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="image_url" type="VARCHAR(500)"/>
            <column name="status" type="VARCHAR(20)" defaultValue="SENT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="chat_messages" indexName="idx_msg_conversation">
            <column name="conversation_id"/>
        </createIndex>
        <createIndex tableName="chat_messages" indexName="idx_msg_sender">
            <column name="sender_id"/>
        </createIndex>
        <createIndex tableName="chat_messages" indexName="idx_msg_created">
            <column name="created_at"/>
        </createIndex>
    </changeSet>

    <!-- ChangeSet 3.3: Create notifications table (NOTF-01 to NOTF-04) -->
    <changeSet id="008-create-notifications-table" author="system">
        <createTable tableName="notifications">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="content" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="reference_id" type="BIGINT"/>
            <column name="reference_type" type="VARCHAR(30)"/>
            <column name="is_read" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="read_at" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="notifications" indexName="idx_notif_user">
            <column name="user_id"/>
        </createIndex>
        <createIndex tableName="notifications" indexName="idx_notif_read">
            <column name="user_id"/>
            <column name="is_read"/>
        </createIndex>
        <createIndex tableName="notifications" indexName="idx_notif_created">
            <column name="created_at"/>
        </createIndex>

        <addForeignKeyConstraint baseTableName="notifications" baseColumnNames="user_id"
                                 constraintName="fk_notifications_user"
                                 referencedTableName="users" referencedColumnNames="id"/>
    </changeSet>
</databaseChangeLog>