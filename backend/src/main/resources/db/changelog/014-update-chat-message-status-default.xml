<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="014-update-chat-message-status-default" author="system">
        <update tableName="chat_messages">
            <column name="status" value="PERSISTED"/>
            <where>status = 'SENT'</where>
        </update>

        <dropDefaultValue tableName="chat_messages"
                          columnName="status"
                          columnDataType="VARCHAR(20)"/>

        <addDefaultValue tableName="chat_messages"
                         columnName="status"
                         columnDataType="VARCHAR(20)"
                         defaultValue="PERSISTED"/>
    </changeSet>
</databaseChangeLog>
